              <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor">
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="script">// ================================
// Step 3 Inputs
// ================================
def startDate        = vars.get(&quot;dp_startdate&quot;)
def insuranceSum     = (vars.get(&quot;dc_insurancesum1&quot;)).toDouble()
def meritRating      = vars.get(&quot;dc_meritrating1&quot;)
def damageInsurance  = vars.get(&quot;dc_damageinsurance1&quot;)
def optionalProducts = &quot;Yes&quot;
def courtesyCar      = vars.get(&quot;dc_courtesycar1&quot;)
def annualMileage    = (vars.get(&quot;dp_mileage&quot;)).toDouble()
def listPrice        = (vars.get(&quot;dp_listprice&quot;)).toDouble()
def enginePerformance= (vars.get(&quot;dp_kw&quot;)).toDouble()
def numberOfSeats    = (vars.get(&quot;dc_no_of_seats1&quot;)).toInteger()
def legalDefense     = &quot;No&quot;
def choosePrice      = vars.get(&quot;dc_chooseprice&quot;)

// ================================
// Function: Compute Automobile Liability
// ================================
double computeAutomobileLiability(double insSum, String meritrating, String courtesyCar) {
    double al = 250 * (100 + (insSum/1000000 - 7)*1.5 )/100
    def bonmal = 100

    switch(meritrating) {
        case &apos;Super Bonus&apos;: bonmal = 35; break
        case &apos;Bonus 1&apos;: bonmal = 40; break
        case &apos;Bonus 2&apos;: bonmal = 45; break
        case &apos;Bonus 3&apos;: bonmal = 50; break
        case &apos;Bonus 4&apos;: bonmal = 55; break
        default: bonmal = 100
    }

    al *= bonmal/100
    if(courtesyCar == &quot;Yes&quot;) al += 100
    return al
}

// ================================
// Function: Compute Premium Tax
// ================================
double computePremiumTax(double enginePerformance) {
    double pt = (enginePerformance - 24) * 0.55
    pt = pt &gt; 160 ? 160 : pt
    pt = pt &lt; 5   ? 5   : pt
    return pt * 12
}

// ================================
// Function: Compute Coverage
// ================================
double computeCoverage(String damageInsurance, double annualMileage, double listPrice, double enginePerformance) {
    double factorKW = enginePerformance &lt;= 100 ? 3 :
                      enginePerformance &lt;= 150 ? 5 : 7

    double pdi = 0
    switch(damageInsurance) {
        case &apos;Full Coverage&apos;:
            pdi = (annualMileage/20000) * (listPrice/1000) * factorKW * 1.35
            break
        case &apos;Partial coverage&apos;:
            pdi = (annualMileage/20000) * (listPrice/1000) * factorKW * 1.0
            break
        case &apos;No Coverage&apos;:
            pdi = 0.0
            break
    }
    return pdi
}

// ================================
// Function: Compute Legal Defense
// ================================
double computeLegalDefenseInsurance(boolean legalDefenseSelected, int numberOfSeats) {
    return legalDefenseSelected ? 92.3 * numberOfSeats : 0
}

// ================================
// Step 4: Calculate total premium
// ================================
boolean legalDefenseSelected = (legalDefense == &quot;Yes&quot;)

double totalPremium =
        computeAutomobileLiability(insuranceSum, meritRating, courtesyCar) +
        computePremiumTax(enginePerformance) +
        computeCoverage(damageInsurance, annualMileage, listPrice, enginePerformance) +
        computeLegalDefenseInsurance(legalDefenseSelected, numberOfSeats)

// ================================
// Apply selected price plan
// ================================
switch(choosePrice) {
    case &quot;Silver&quot;:
        totalPremium = (totalPremium * 1.2 * 109 / 100) / 12
        break
    case &quot;Gold&quot;:
        totalPremium = (totalPremium * 1.2 * 107 / 100) / 4
        break
    case &quot;Platinum&quot;:
        totalPremium = (totalPremium * 1.2 * 105 / 100) / 2
        break
    case &quot;Ultimate&quot;:
        totalPremium = totalPremium * 1.2
        break
    default:
        totalPremium = 0
}

// ================================
// Round to XX.00 (always .00)
// ================================
def integerPart = (int) totalPremium
def finalValue = String.format(&apos;%.2f&apos;, integerPart as double)

// Store results
vars.put(&quot;valueRounded&quot;, finalValue)
vars.put(&quot;dp_pricesum&quot;, finalValue.toString())

log.info(&quot;Step 4 - Calculated Premium: &quot; + totalPremium)
log.info(&quot;value rounded: &quot; + finalValue)
</stringProp>
